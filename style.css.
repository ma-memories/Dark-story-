/* =========================================================
   DARK STORY
   style.css - PART 1
   Theme: Classified File / Top Secret
   ========================================================= */

/* Google Font */
@import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Special+Elite&display=swap');

/* ==========================
   RESET
========================== */

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

html{
    scroll-behavior:smooth;
}

body{
    background:#090909;
    color:#e6e6e6;
    overflow-x:hidden;
    font-family:'Special Elite', monospace;
}

/* ==========================
   SCROLLBAR
========================== */

::-webkit-scrollbar{
    width:8px;
}

::-webkit-scrollbar-track{
    background:#111;
}

::-webkit-scrollbar-thumb{
    background:#6d0000;
}

::-webkit-scrollbar-thumb:hover{
    background:#b30000;
}

/* ==========================
   LOADING SCREEN
========================== */

#loading{
    position:fixed;
    inset:0;
    background:#000;
    display:flex;
    justify-content:center;
    align-items:center;
    flex-direction:column;
    z-index:99999;
}

#loading h1{
    color:#d4d4d4;
    font-size:18px;
    letter-spacing:6px;
    animation:blink 1.2s infinite;
}

#loading p{
    margin-top:20px;
    color:#7f7f7f;
    font-size:14px;
    letter-spacing:3px;
}

@keyframes blink{

    0%{
        opacity:.2;
    }

    50%{
        opacity:1;
    }

    100%{
        opacity:.2;
    }

}

/* ==========================
   BOOK
========================== */

#book{

    width:100%;
    min-height:100vh;

    display:flex;
    justify-content:center;
    align-items:center;
    flex-direction:column;

    padding:80px 20px;

}

/* ==========================
   COVER
========================== */

.cover{

    width:min(900px,95%);
    min-height:650px;

    background:#d6c7a2;

    border-radius:8px;

    border:10px solid #463826;

    box-shadow:
    0 0 50px rgba(0,0,0,.8),
    inset 0 0 100px rgba(0,0,0,.25);

    display:flex;

    justify-content:center;
    align-items:center;

    flex-direction:column;

    text-align:center;

    position:relative;

    overflow:hidden;

}

/* Paper texture */

.cover::before{

    content:"";

    position:absolute;

    inset:0;

    background:
    radial-gradient(circle,rgba(255,255,255,.06) 1px,transparent 1px);

    background-size:12px 12px;

    opacity:.35;

}

/* Top Secret Stamp */

.cover::after{

    content:"TOP SECRET";

    position:absolute;

    top:45px;

    right:-45px;

    transform:rotate(18deg);

    padding:12px 60px;

    border:5px solid #990000;

    color:#990000;

    font-size:28px;

    font-weight:bold;

    letter-spacing:4px;

    opacity:.8;

}

/* ==========================
   COVER TEXT
========================== */

.cover h1{

    font-family:'Cinzel',serif;

    color:#111;

    font-size:72px;

    letter-spacing:8px;

    margin-bottom:20px;

}

.cover h2{

    color:#400;

    font-size:32px;

    margin-bottom:35px;

}

.cover p{

    color:#2a2a2a;

    font-size:22px;

    margin:8px;

    letter-spacing:2px;

}

/* ==========================
   BUTTON
========================== */

#openBtn{

    margin-top:70px;

    padding:18px 60px;

    border:none;

    background:#1a1a1a;

    color:white;

    font-size:20px;

    cursor:pointer;

    letter-spacing:3px;

    transition:.35s;

    border-radius:4px;

}

#openBtn:hover{

    background:#990000;

    transform:scale(1.05);

    box-shadow:0 0 25px rgba(255,0,0,.4);

}

/* ==========================
   PAGE
========================== */

.page{

    width:min(900px,95%);

    min-height:650px;

    background:#efe5c9;

    color:#111;

    margin-top:70px;

    padding:70px;

    border-radius:6px;

    box-shadow:
    0 0 45px rgba(0,0,0,.5);

    display:none;

    position:relative;

}

.page.active{

    display:block;

    animation:fadePage .8s;

}

@keyframes fadePage{

    from{

        opacity:0;
        transform:translateY(20px);

    }

    to{

        opacity:1;
        transform:translateY(0);

    }

}

/* ==========================
   PAGE TITLES
========================== */

.page h2{

    font-family:'Cinzel',serif;

    font-size:38px;

    margin-bottom:35px;

    border-bottom:2px solid #444;

    padding-bottom:10px;

}

.page p{

    font-size:22px;

    line-height:1.9;

    margin-bottom:22px;

}

/* ==========================
   TYPEWRITER EFFECT
========================== */

.typewriter{

    overflow:hidden;

    white-space:pre-wrap;

    border-right:3px solid #111;

    animation:cursor .8s infinite;

}

@keyframes cursor{

    50%{

        border-color:transparent;

    }

}
/* =========================================================
   DARK STORY
   style.css - PART 2
   ========================================================= */

/* ==========================
   DIALOG BOX
========================== */

.dialog{

    margin:35px 0;

    padding:30px;

    border-left:6px solid #700000;

    background:#f8f3e5;

    box-shadow:0 10px 20px rgba(0,0,0,.15);

}

.dialog.doctor{

    border-left-color:#202020;

}

.dialog.ali{

    border-left-color:#9b0000;

}

.speaker{

    font-family:'Cinzel',serif;

    font-size:28px;

    font-weight:bold;

    margin-bottom:18px;

}

.quote{

    font-style:italic;

    color:#444;

}

/* ==========================
   TATTOO ANALYSIS
========================== */

.analysis{

    display:grid;

    grid-template-columns:1fr 1fr;

    gap:40px;

    margin-top:50px;

}

.analysis-card{

    background:#f9f6ea;

    padding:30px;

    border:2px solid #bbb;

    transition:.35s;

}

.analysis-card:hover{

    transform:translateY(-8px);

    box-shadow:0 20px 35px rgba(0,0,0,.18);

}

.analysis-card h3{

    font-family:'Cinzel',serif;

    margin-bottom:20px;

    color:#600000;

}

.analysis-card p{

    font-size:19px;

}

/* ==========================
   FINAL PAGE
========================== */

.final-page{

    text-align:center;

}

.final-page h2{

    border:none;

    font-size:50px;

    letter-spacing:6px;

}

.final-page h3{

    margin-top:40px;

    font-size:30px;

    color:#700000;

}

/* ==========================
   PHOTO WALL
========================== */

.gallery{

    margin-top:60px;

    display:grid;

    grid-template-columns:repeat(2,1fr);

    gap:35px;

}

.gallery img{

    width:100%;

    border:10px solid #fff;

    background:#fff;

    padding:10px;

    box-shadow:0 18px 35px rgba(0,0,0,.35);

    transition:.4s;

    transform:rotate(-2deg);

}

.gallery img:nth-child(2){

    transform:rotate(2deg);

}

.gallery img:nth-child(3){

    transform:rotate(3deg);

}

.gallery img:nth-child(4){

    transform:rotate(-3deg);

}

.gallery img:hover{

    transform:scale(1.05) rotate(0deg);

}

/* ==========================
   TAPE EFFECT
========================== */

.gallery img::before{

    content:"";

    display:block;

}

.photo{

    position:relative;

}

.photo::before{

    content:"";

    position:absolute;

    width:90px;

    height:28px;

    background:rgba(255,255,220,.65);

    top:-14px;

    left:50%;

    transform:translateX(-50%) rotate(-4deg);

}

/* ==========================
   CASE STAMP
========================== */

.case-stamp{

    margin:70px auto;

    width:max-content;

    padding:18px 55px;

    border:6px solid #b00000;

    color:#b00000;

    font-size:38px;

    font-weight:bold;

    transform:rotate(-10deg);

    opacity:.85;

    letter-spacing:5px;

}

/* ==========================
   REBORN STATUS
========================== */

.status{

    margin-top:30px;

    font-size:26px;

    letter-spacing:3px;

}

.status span{

    color:#9b0000;

    font-weight:bold;

}

/* ==========================
   END MESSAGE
========================== */

.end-message{

    margin-top:70px;

    text-align:center;

}

.end-message h2{

    font-size:42px;

    border:none;

    margin-bottom:25px;

}

.end-message p{

    font-size:24px;

    line-height:2;

}

/* ==========================
   BLACK SCREEN
========================== */

.black-screen{

    position:fixed;

    inset:0;

    background:#000;

    color:#fff;

    display:flex;

    justify-content:center;

    align-items:center;

    flex-direction:column;

    text-align:center;

    opacity:0;

    pointer-events:none;

    transition:1s;

    z-index:999999;

}

.black-screen.show{

    opacity:1;

}

.black-screen h1{

    font-size:50px;

    font-family:'Cinzel',serif;

    margin-bottom:30px;

}

.black-screen p{

    font-size:24px;

    max-width:850px;

    line-height:2;

}

/* ==========================
   NEXT BUTTON
========================== */

.next-btn{

    margin-top:50px;

    padding:16px 45px;

    background:#111;

    color:#fff;

    border:none;

    cursor:pointer;

    font-size:18px;

    letter-spacing:3px;

    transition:.3s;

}

.next-btn:hover{

    background:#900000;

}
/* =========================================================
   DARK STORY
   style.css - PART 3 (FINAL)
   ========================================================= */

/* ==========================
   FILE OPEN ANIMATION
========================== */

.open-file{

    animation:fileOpen 1.2s ease forwards;

}

@keyframes fileOpen{

    0%{

        transform:scale(.92) rotateY(0deg);
        opacity:0;

    }

    50%{

        transform:scale(1.03) rotateY(-8deg);

    }

    100%{

        transform:scale(1);
        opacity:1;

    }

}

/* ==========================
   PAGE TURN
========================== */

.page-turn{

    animation:pageTurn .9s ease;

}

@keyframes pageTurn{

    0%{

        transform:perspective(1200px) rotateY(0);

    }

    50%{

        transform:perspective(1200px) rotateY(-80deg);

    }

    100%{

        transform:perspective(1200px) rotateY(0);

    }

}

/* ==========================
   FADE IN
========================== */

.fade-in{

    animation:fadeIn 1s ease forwards;

}

@keyframes fadeIn{

    from{

        opacity:0;
        transform:translateY(25px);

    }

    to{

        opacity:1;
        transform:translateY(0);

    }

}

/* ==========================
   STAMP EFFECT
========================== */

.stamp-animation{

    animation:stamp .6s ease;

}

@keyframes stamp{

    0%{

        transform:scale(3) rotate(-18deg);
        opacity:0;

    }

    60%{

        transform:scale(.85);

    }

    100%{

        transform:scale(1) rotate(-10deg);
        opacity:1;

    }

}

/* ==========================
   PHOTO APPEAR
========================== */

.gallery img{

    opacity:0;

    animation:photoAppear .8s ease forwards;

}

.gallery img:nth-child(1){

    animation-delay:.3s;

}

.gallery img:nth-child(2){

    animation-delay:.8s;

}

.gallery img:nth-child(3){

    animation-delay:1.3s;

}

.gallery img:nth-child(4){

    animation-delay:1.8s;

}

@keyframes photoAppear{

    from{

        opacity:0;
        transform:translateY(80px) rotate(15deg);

    }

    to{

        opacity:1;
        transform:translateY(0);

    }

}

/* ==========================
   RED WORD
========================== */

.red{

    color:#b00000;

    font-weight:bold;

}

/* ==========================
   FOOTER
========================== */

footer{

    margin-top:80px;

    text-align:center;

    color:#888;

    font-size:15px;

    letter-spacing:3px;

    padding-bottom:40px;

}

/* ==========================
   MOBILE
========================== */

@media(max-width:900px){

.cover{

    min-height:auto;

    padding:70px 25px;

}

.cover h1{

    font-size:42px;

    letter-spacing:4px;

}

.cover h2{

    font-size:22px;

}

.cover p{

    font-size:18px;

}

.page{

    padding:35px 25px;

    min-height:auto;

}

.page h2{

    font-size:28px;

}

.page p{

    font-size:18px;

}

.analysis{

    grid-template-columns:1fr;

}

.gallery{

    grid-template-columns:1fr;

}

.case-stamp{

    font-size:24px;

    padding:15px 25px;

}

.black-screen h1{

    font-size:30px;

}

.black-screen p{

    font-size:18px;

    padding:0 20px;

}

}

/* ==========================
   LARGE SCREEN
========================== */

@media(min-width:1500px){

.cover,
.page{

    max-width:1100px;

}

.page p{

    font-size:24px;

}

}

/* ==========================
   SELECTION
========================== */

::selection{

    background:#8b0000;

    color:#fff;

}

/* ==========================
   END
========================== */
